<% initial_signup = !User.exists? %>
<% content_for :title, initial_signup ? "初期ユーザー登録" : "ユーザー追加" %>

<div class="page-shell auth-shell">
  <section class="panel form-panel auth-panel">
    <h1><%= initial_signup ? "初期ユーザー登録" : "ユーザー追加" %></h1>
    <% unless initial_signup %>
      <p class="field-hint">ログインIDは作成時に自動採番されます。</p>
    <% end %>

    <% if @user.errors.any? %>
      <div class="flash flash-alert">
        <strong>登録できませんでした</strong>
        <ul>
          <% @user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: @user, class: "report-form" do |form| %>
      <div class="field-grid">
        <div class="field">
          <%= form.label :name, "名前" %>
          <%= form.text_field :name, required: true %>
        </div>

        <div class="field">
          <%= form.label :email, "メールアドレス" %>
          <%= form.email_field :email, required: true, autocomplete: "username", autocapitalize: "none", autocorrect: "off", spellcheck: false, inputmode: "email", data: { email_normalize: true } %>
        </div>

        <div class="field">
          <%= form.label :region_id, "聖院" %>
          <%= form.collection_select :region_id, @regions, :id, :name, { prompt: "選択してください" }, { required: true } %>
        </div>

        <% if current_user&.admin? %>
          <div class="field checkbox-field">
            <label>
              <%= form.check_box :admin %>
              管理者
            </label>
          </div>
        <% end %>

        <div class="field">
          <%= form.label :password, "パスワード" %>
          <%= form.password_field :password, required: true %>
        </div>

        <div class="field">
          <%= form.label :password_confirmation, "パスワード確認" %>
          <%= form.password_field :password_confirmation, required: true %>
        </div>
      </div>

      <div class="actions">
        <%= form.submit "作成する", class: "button-primary" %>
      </div>
    <% end %>
  </section>
</div>
