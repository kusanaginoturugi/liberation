<% content_for :title, "伝道会一覧" %>

<div class="page-shell">
  <div class="panel">
    <div class="panel-header">
      <h1>伝道会一覧</h1>
      <%= link_to "伝道会追加", new_evangelism_meeting_path, class: "button-secondary" %>
    </div>

    <% if flash[:notice].present? %>
      <div class="flash flash-notice"><%= flash[:notice] %></div>
    <% end %>

    <table class="admin-table">
      <thead>
        <tr>
          <th>伝道会名</th>
          <th>聖院</th>
          <th>色</th>
          <th>表示順</th>
          <th>有効</th>
        </tr>
      </thead>
      <tbody>
        <% @evangelism_meetings.each do |meeting| %>
          <tr class="clickable-row" data-href="<%= edit_evangelism_meeting_path(meeting) %>" tabindex="0" role="link" aria-label="<%= "#{meeting.name}を編集" %>">
            <td><%= meeting.name %></td>
            <td><%= meeting.region.name %></td>
            <td><span class="legend-swatch" style="<%= "--swatch-color: #{meeting.color_code}" %>"></span> <%= meeting.color_code %></td>
            <td><%= meeting.display_order %></td>
            <td><%= meeting.active? ? "有効" : "無効" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll(".clickable-row[data-href]").forEach((row) => {
      row.addEventListener("click", () => {
        window.location.href = row.dataset.href;
      });

      row.addEventListener("keydown", (event) => {
        if (event.key === "Enter" || event.key === " ") {
          event.preventDefault();
          window.location.href = row.dataset.href;
        }
      });
    });
  });
</script>
