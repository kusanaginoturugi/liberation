<% content_for :title, "ログイン" %>

<div class="page-shell auth-shell">
  <section class="panel form-panel auth-panel">
    <h1>ログイン</h1>

    <% if flash[:notice].present? %>
      <div class="flash flash-notice"><%= flash[:notice] %></div>
    <% end %>

    <% if flash[:alert].present? %>
      <div class="flash flash-alert"><%= flash[:alert] %></div>
    <% end %>

    <%= form_with url: session_path, class: "report-form" do |form| %>
      <div class="field-grid">
        <div class="field">
          <%= form.label :login_id, "ログインID" %>
          <%= form.text_field :login_id, value: params[:login_id], required: true, autofocus: true, autocomplete: "username", autocapitalize: "none", autocorrect: "off", spellcheck: false, data: { login_id_normalize: true } %>
          <small class="field-hint">全角英数字や空白は自動で半角に直します。</small>
        </div>

        <div class="field">
          <%= form.label :password, "パスワード" %>
          <%= form.password_field :password, required: true, autocomplete: "current-password" %>
        </div>
      </div>

      <div class="field">
        <span class="field-label">ログイン状態</span>
        <div class="radio-group">
          <label class="radio-option">
            <%= radio_button_tag :remember_me, "1", params.fetch(:remember_me, "1") != "0" %>
            保持する
          </label>
          <label class="radio-option">
            <%= radio_button_tag :remember_me, "0", params.fetch(:remember_me, "1") == "0" %>
            今回のみ
          </label>
        </div>
        <small class="field-hint">共有の端末では、使い終わったあとに必ずログアウトしてください。</small>
      </div>

      <div class="actions">
        <%= form.submit "ログイン", class: "button-primary" %>
      </div>
    <% end %>
  </section>
</div>
