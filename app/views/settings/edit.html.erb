<% content_for :title, "設定" %>

<div class="page-shell auth-shell">
  <section class="panel form-panel auth-panel">
    <h1>設定</h1>

    <% if flash[:notice].present? %>
      <div class="flash flash-notice"><%= flash[:notice] %></div>
    <% end %>

    <%= form_with url: settings_path, method: :patch, scope: :settings, class: "report-form" do |form| %>
      <div class="field-grid">
        <div class="field">
          <span class="field-label">配色のグラデーション</span>
          <div class="radio-group">
            <label class="radio-option">
              <%= form.radio_button :gradient_enabled, "true", checked: @gradient_enabled %>
              有効
            </label>
            <label class="radio-option">
              <%= form.radio_button :gradient_enabled, "false", checked: !@gradient_enabled %>
              無効
            </label>
          </div>
        </div>
        <div class="field">
          <span class="field-label">数字のドロップシャドウ</span>
          <div class="radio-group">
            <label class="radio-option">
              <%= form.radio_button :number_shadow_enabled, "true", checked: @number_shadow_enabled %>
              有効
            </label>
            <label class="radio-option">
              <%= form.radio_button :number_shadow_enabled, "false", checked: !@number_shadow_enabled %>
              無効
            </label>
          </div>
        </div>
      </div>

      <div class="actions">
        <%= form.submit "更新する", class: "button-primary" %>
      </div>
    <% end %>
  </section>
</div>
