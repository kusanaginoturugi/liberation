<% content_for :title, "超抜式編集" %>

<div class="page-shell auth-shell">
  <section class="panel form-panel auth-panel">
    <h1>超抜式編集</h1>

    <% if @event.errors.any? %>
      <div class="flash flash-alert">
        <strong>更新できませんでした</strong>
        <ul>
          <% @event.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: @event, class: "report-form" do |form| %>
      <div class="field-grid">
        <div class="field">
          <%= form.label :name, "超抜式名" %>
          <%= form.text_field :name, required: true, autofocus: true %>
        </div>

        <% if single_region_mode? %>
          <div class="field">
            <%= form.label :total_serial_count, "修霊合計数" %>
            <%= number_field_tag "event[total_serial_count]", @total_serial_count_input, min: 1, required: true, inputmode: "numeric", pattern: "[0-9]*", data: { numeric_only: true } %>
          </div>
        <% end %>

        <div class="field">
          <span class="field-label">状態</span>
          <div class="radio-group">
            <label class="radio-option">
              <%= form.radio_button :closed, false %>
              開催中
            </label>
            <label class="radio-option">
              <%= form.radio_button :closed, true %>
              終了
            </label>
          </div>
          <p class="field-hint">開催中にすると、他の超抜式は自動で終了になります。</p>
        </div>
      </div>

      <div class="actions">
        <%= form.submit "更新する", class: "button-primary" %>
      </div>
    <% end %>

    <div class="actions">
      <% if @event.chobatsu_reports.exists? %>
        <button type="button" class="button-secondary" disabled>削除できません</button>
        <p class="field-hint">超抜報告が紐づいている超抜式は削除できません</p>
      <% else %>
        <%= button_to "削除する", event_path(@event), method: :delete,
            class: "button-danger",
            form: { data: { turbo_confirm: "この超抜式を削除しますか？" } } %>
      <% end %>
    </div>
  </section>
</div>
