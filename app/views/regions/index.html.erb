<% content_for :title, "聖院一覧" %>

<div class="page-shell">
  <div class="panel">
    <div class="panel-header">
      <h1>聖院一覧</h1>
    </div>

    <% if flash[:notice].present? %>
      <div class="flash flash-notice"><%= flash[:notice] %></div>
    <% end %>

    <table class="admin-table">
      <thead>
        <tr>
          <th>聖院名</th>
          <th>操作</th>
        </tr>
      </thead>
      <tbody>
        <% @regions.each do |region| %>
          <tr>
            <td><%= region.name %></td>
            <td><%= link_to "編集", edit_region_path(region), class: "text-link" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
