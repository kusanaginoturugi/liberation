<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Liberation" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  </head>

  <body>
    <header class="app-nav">
      <div class="app-nav__inner">
        <% if user_signed_in? %>
          <div>
            <strong><%= current_user.name %></strong>
            <span><%= current_user.region.name %></span>
          </div>
        <% else %>
          <div>
            <strong>Liberation</strong>
          </div>
        <% end %>
        <div class="app-nav__actions">
          <%= link_to "修霊番号一覧", root_path, class: "button-secondary" %>
          <% if user_signed_in? %>
            <%= link_to "修霊番号登録", new_chobatsu_report_path, class: "button-secondary" %>
            <%= link_to "超抜集計", summary_chobatsu_reports_path, class: "button-secondary" %>
            <% if current_user.admin? %>
              <details class="nav-dropdown">
                <summary class="button-secondary nav-dropdown__summary">管理</summary>
                <div class="nav-dropdown__menu">
                  <% unless single_region_mode? %>
                    <%= link_to "聖院一覧", regions_path, class: "nav-dropdown__item" %>
                  <% end %>
                  <%= link_to "超抜式一覧", events_path, class: "nav-dropdown__item" %>
                  <%= link_to "伝道会一覧", evangelism_meetings_path, class: "nav-dropdown__item" %>
                </div>
              </details>
            <% end %>
            <%= button_to "ログアウト", session_path, method: :delete, class: "button-secondary" %>
          <% else %>
            <%= link_to "超抜集計", summary_chobatsu_reports_path, class: "button-secondary" %>
            <%= link_to "ログイン", new_session_path, class: "button-secondary" %>
          <% end %>
        </div>
      </div>
    </header>
    <%= yield %>
  </body>
</html>
