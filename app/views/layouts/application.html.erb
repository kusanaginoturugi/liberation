<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Liberation" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  </head>

  <body class="<%= [gradient_enabled? ? 'gradient-enabled' : 'gradient-disabled', number_shadow_enabled? ? 'number-shadow-enabled' : 'number-shadow-disabled'].join(' ') %>">
    <header class="app-nav">
      <div class="app-nav__inner">
        <% if user_signed_in? %>
          <%= link_to edit_user_path(current_user), class: "nav-user-link" do %>
            <strong><%= current_user.name %><%= "（管理者）" if current_user.admin? %></strong>
            <span><%= current_user.region.name %></span>
          <% end %>
        <% else %>
          <div>
            <strong>Liberation</strong>
          </div>
        <% end %>
        <div class="app-nav__actions">
          <%= link_to "修霊番号一覧", root_path, class: "button-secondary" %>
          <% if user_signed_in? %>
            <%= link_to "挙行報告", new_chobatsu_report_path, class: "button-secondary" %>
            <%= link_to "挙行一覧", summary_chobatsu_reports_path, class: "button-secondary" %>
            <% if current_user.admin? %>
              <details class="nav-dropdown">
                <summary class="button-secondary nav-dropdown__summary">管理</summary>
                <div class="nav-dropdown__menu">
                  <% unless single_region_mode? %>
                    <%= link_to "聖院一覧", regions_path, class: "nav-dropdown__item" %>
                  <% end %>
                  <%= link_to "設定", edit_settings_path, class: "nav-dropdown__item" %>
                  <%= link_to "ユーザー一覧", users_path, class: "nav-dropdown__item" %>
                  <%= link_to "超抜式一覧", events_path, class: "nav-dropdown__item" %>
                  <%= link_to "伝道会一覧", evangelism_meetings_path, class: "nav-dropdown__item" %>
                </div>
              </details>
            <% end %>
            <%= button_to "ログアウト", session_path, method: :delete, class: "button-secondary" %>
          <% else %>
            <%= link_to "挙行一覧", summary_chobatsu_reports_path, class: "button-secondary" %>
            <%= link_to "ログイン", new_session_path, class: "button-secondary" %>
          <% end %>
        </div>
      </div>
    </header>
    <%= yield %>

    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const normalizeNumericValue = (value) =>
          value
            .replace(/[０-９]/g, (character) => String.fromCharCode(character.charCodeAt(0) - 0xFEE0))
            .replace(/\D/g, "");
        const normalizeEmailValue = (value) =>
          value
            .normalize("NFKC")
            .replace(/\s+/g, "")
            .toLowerCase();
        const normalizeLoginIdValue = (value) =>
          value
            .normalize("NFKC")
            .replace(/\s+/g, "");

        const numericOnlyField = (target) => {
          if (!(target instanceof HTMLInputElement)) return null;
          if (target.dataset.numericOnly !== "true") return null;

          return target;
        };
        const emailNormalizeField = (target) => {
          if (!(target instanceof HTMLInputElement)) return null;
          if (target.dataset.emailNormalize !== "true") return null;

          return target;
        };
        const loginIdNormalizeField = (target) => {
          if (!(target instanceof HTMLInputElement)) return null;
          if (target.dataset.loginIdNormalize !== "true") return null;

          return target;
        };

        const sanitizeNumericField = (field) => {
          const normalizedValue = normalizeNumericValue(field.value);
          if (field.value !== normalizedValue) {
            field.value = normalizedValue;
          }
        };
        const sanitizeEmailField = (field) => {
          const normalizedValue = normalizeEmailValue(field.value);
          if (field.value !== normalizedValue) {
            field.value = normalizedValue;
          }
        };
        const sanitizeLoginIdField = (field) => {
          const normalizedValue = normalizeLoginIdValue(field.value);
          if (field.value !== normalizedValue) {
            field.value = normalizedValue;
          }
        };

        document.addEventListener("compositionstart", (event) => {
          const field = numericOnlyField(event.target) || emailNormalizeField(event.target) || loginIdNormalizeField(event.target);
          if (!field) return;

          field.dataset.composing = "true";
        });

        document.addEventListener("compositionend", (event) => {
          const numericField = numericOnlyField(event.target);
          if (numericField) {
            delete numericField.dataset.composing;
            sanitizeNumericField(numericField);
            return;
          }

          const emailField = emailNormalizeField(event.target);
          if (emailField) {
            delete emailField.dataset.composing;
            sanitizeEmailField(emailField);
            return;
          }

          const loginIdField = loginIdNormalizeField(event.target);
          if (!loginIdField) return;

          delete loginIdField.dataset.composing;
          sanitizeLoginIdField(loginIdField);
        });

        document.addEventListener("input", (event) => {
          const numericField = numericOnlyField(event.target);
          if (numericField) {
            if (numericField.dataset.composing === "true") return;

            sanitizeNumericField(numericField);
            return;
          }

          const emailField = emailNormalizeField(event.target);
          if (emailField) {
            if (emailField.dataset.composing === "true") return;

            sanitizeEmailField(emailField);
            return;
          }

          const loginIdField = loginIdNormalizeField(event.target);
          if (!loginIdField) return;
          if (loginIdField.dataset.composing === "true") return;

          sanitizeLoginIdField(loginIdField);
        });

        document.addEventListener("blur", (event) => {
          const emailField = emailNormalizeField(event.target);
          if (emailField) {
            sanitizeEmailField(emailField);
            return;
          }

          const loginIdField = loginIdNormalizeField(event.target);
          if (!loginIdField) return;

          sanitizeLoginIdField(loginIdField);
        }, true);
      });
    </script>
  </body>
</html>
