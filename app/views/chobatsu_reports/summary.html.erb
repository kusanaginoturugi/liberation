<% content_for :title, "挙行一覧" %>

<div class="page-shell">
  <header class="page-header">
    <div>
      <p class="eyebrow">Ceremony List</p>
      <h1>挙行一覧</h1>
    </div>
    <div class="page-header-actions">
      <%= link_to "CSV出力",
          export_chobatsu_reports_path(format: :csv, event_id: @selected_event&.id, region_id: @selected_region&.id),
          class: "button-secondary compact-button" %>
      <%= link_to "PDF出力",
          export_chobatsu_reports_path(event_id: @selected_event&.id, region_id: @selected_region&.id),
          class: "button-secondary compact-button",
          target: "_blank",
          rel: "noopener" %>
    </div>
  </header>

  <section class="panel region-filter-panel">
    <%= form_with url: summary_chobatsu_reports_path, method: :get, class: "region-filter-form" do |form| %>
      <% unless single_region_mode? %>
        <div class="field">
          <%= form.label :region_id, "聖院" %>
          <%= form.collection_select :region_id, @regions, :id, :name, { selected: @selected_region&.id }, { onchange: "this.form.requestSubmit()" } %>
        </div>
      <% end %>
      <div class="field">
        <%= form.label :event_id, "超抜式" %>
        <%= form.collection_select :event_id, @events, :id, :name, { selected: @selected_event&.id }, { onchange: "this.form.requestSubmit()" } %>
      </div>
    <% end %>
  </section>

  <section class="panel">
    <div class="panel-header">
      <h2>登録一覧</h2>
      <p><%= @summary_reports.size %> 件</p>
    </div>

    <div class="summary-table-wrapper">
      <table class="admin-table summary-table">
        <thead>
          <tr>
            <th style="width: 3em">No.</th>
            <th style="width: 7em">
              <%= link_to summary_chobatsu_reports_path(
                    event_id: @selected_event&.id,
                    region_id: @selected_region&.id,
                    direction: @summary_sort_direction == :asc ? :desc : :asc
                  ),
                  class: "summary-sort-link" do %>
                挙行日
                <span><%= @summary_sort_direction == :asc ? "↑" : "↓" %></span>
              <% end %>
            </th>
            <th>伝道会名</th>
            <th class="summary-number" style="width: 6em">超抜霊数</th>
            <th class="summary-number" style="width: 7em">(内)ノアカード分</th>
            <th class="summary-number" style="width: 7em">功徳費合計</th>
            <th class="summary-number" style="width: 7em">
              みろく寺分
              <br><small style="font-size: 0.75em; font-weight: normal">(ノア分勘案せず)</small>
            </th>
            <th class="summary-number" style="width: 6em">聖院還付金</th>
            <th>備考欄</th>
            <th style="width: 6em">入力者名</th>
          </tr>
        </thead>
        <tbody>
          <% @summary_reports.each_with_index do |report, index| %>
            <tr>
              <td><%= index + 1 %></td>
              <td><%= report.ceremony_date.strftime("%Y/%m/%d") %></td>
              <td><%= report.evangelism_meeting.name %></td>
              <td class="summary-number"><%= number_with_delimiter(report.participant_count) %></td>
              <td class="summary-number"><%= report.noah_card_count.present? ? number_with_delimiter(report.noah_card_count) : "-" %></td>
              <td class="summary-number"><%= number_with_delimiter(report.calculated_merit_fee_total) %></td>
              <td class="summary-number"><%= number_with_delimiter(report.mirokuji_share) %></td>
              <td class="summary-number"><%= number_with_delimiter(report.region_refund) %></td>
              <td><%= report.notes %></td>
              <td><%= report.user&.name || "未設定" %></td>
            </tr>
          <% end %>
          <% if @summary_reports.empty? %>
            <tr>
              <td colspan="10" class="summary-empty">該当する超抜報告はありません</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</div>
