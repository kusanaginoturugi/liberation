<% content_for :title, "超抜報告を登録" %>

<div class="page-shell">
  <header class="page-header">
    <div>
      <p class="eyebrow">Chobatsu Report</p>
      <h1>超抜報告を登録</h1>
    </div>
    <div class="setting-card">
      <span>修霊合計数</span>
      <strong><%= @total_serial_count %></strong>
    </div>
  </header>

  <% if flash[:notice].present? %>
    <div class="flash flash-notice"><%= flash[:notice] %></div>
  <% end %>

  <% if @chobatsu_report.errors.any? %>
    <div class="flash flash-alert">
      <strong>登録できませんでした</strong>
      <ul>
        <% @chobatsu_report.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="page-grid">
    <section class="panel form-panel">
      <h2>登録フォーム</h2>

      <%= form_with model: @chobatsu_report, class: "report-form" do |form| %>
        <div class="field-grid">
          <div class="field <%= "field-with-error" if @chobatsu_report.errors[:ceremony_date].any? %>">
            <%= form.label :ceremony_date, "挙行日" %>
            <%= form.date_field :ceremony_date %>
          </div>

          <div class="field <%= "field-with-error" if @chobatsu_report.errors[:evangelism_meeting].any? || @chobatsu_report.errors[:evangelism_meeting_id].any? %>">
            <%= form.label :evangelism_meeting_id, "伝道会名" %>
            <%= form.collection_select :evangelism_meeting_id, @evangelism_meetings, :id, :name, { prompt: "選択してください" } %>
          </div>

          <div class="field <%= "field-with-error" if @chobatsu_report.errors[:event].any? || @chobatsu_report.errors[:event_id].any? %>">
            <%= form.label :event_id, "超抜式" %>
            <%= form.collection_select :event_id, @events, :id, :name, { prompt: false, selected: @chobatsu_report.event_id || @selected_event&.id } %>
          </div>

          <div class="field <%= "field-with-error" if @chobatsu_report.errors[:assistant_name].any? %>">
            <%= form.label :assistant_name, "超抜点伝師名" %>
            <%= form.text_field :assistant_name %>
          </div>

          <div class="field <%= "field-with-error" if @chobatsu_report.errors[:participant_count].any? %>">
            <%= form.label :participant_count, "超抜人数" %>
            <%= form.number_field :participant_count, min: 0, value: @chobatsu_report.participant_count.presence, data: { calc_target: "participant", action: "input->report-form#update" } %>
            <% @chobatsu_report.errors.full_messages_for(:participant_count).each do |message| %>
              <p class="field-error"><%= message %></p>
            <% end %>
          </div>

          <div class="field <%= "field-with-error" if @chobatsu_report.errors[:serial_number_from].any? %>">
            <%= form.label :serial_number_from, "使用修霊番号(始)" %>
            <%= form.number_field :serial_number_from, min: 1, max: @total_serial_count, value: @chobatsu_report.serial_number_from.presence, data: { calc_target: "from", action: "input->report-form#update" } %>
            <% @chobatsu_report.errors.full_messages_for(:serial_number_from).each do |message| %>
              <p class="field-error"><%= message %></p>
            <% end %>
          </div>

          <div class="field <%= "field-with-error" if @chobatsu_report.errors[:serial_number_to].any? %>">
            <%= form.label :serial_number_to, "使用修霊番号(終)" %>
            <%= form.number_field :serial_number_to, min: 1, max: @total_serial_count, value: @chobatsu_report.serial_number_to.presence, data: { calc_target: "to", action: "input->report-form#update" } %>
            <% @chobatsu_report.errors.full_messages_for(:serial_number_to).each do |message| %>
              <p class="field-error"><%= message %></p>
            <% end %>
          </div>

          <div class="field usage-field">
            <span class="field-label">使用数</span>
            <div class="usage-count" data-calc-target="usageOutput"><%= @chobatsu_report.usage_count %></div>
          </div>

          <div class="field usage-field">
            <span class="field-label">功徳費合計</span>
            <div class="usage-count" data-calc-target="meritOutput"><%= @chobatsu_report.calculated_merit_fee_total %></div>
          </div>
        </div>

        <div class="actions">
          <%= form.submit "登録する", class: "button-primary" %>
        </div>
      <% end %>
    </section>

    <%= render "report_grid",
        chobatsu_reports: @chobatsu_reports,
        legend_evangelism_meetings: @legend_evangelism_meetings,
        total_serial_count: @total_serial_count %>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const participantField = document.querySelector("[data-calc-target='participant']");
    const fromField = document.querySelector("[data-calc-target='from']");
    const toField = document.querySelector("[data-calc-target='to']");
    const usageOutput = document.querySelector("[data-calc-target='usageOutput']");
    const meritOutput = document.querySelector("[data-calc-target='meritOutput']");

    const updateTotals = () => {
      const fromValue = Number.parseInt(fromField.value, 10);
      const toValue = Number.parseInt(toField.value, 10);
      let usageCount = 0;

      if (usageOutput) {
        if (Number.isNaN(fromValue) || Number.isNaN(toValue) || toValue < fromValue) {
          usageOutput.textContent = "0";
        } else {
          usageCount = toValue - fromValue + 1;
          usageOutput.textContent = String(usageCount);
        }
      }

      if (meritOutput) {
        meritOutput.textContent = String(usageCount * 5000);
      }
    };

    [participantField, fromField, toField].forEach((field) => {
      if (field) field.addEventListener("input", updateTotals);
    });

    const firstInvalidField = document.querySelector(".field-with-error input, .field-with-error select, .field-with-error textarea");
    if (firstInvalidField) {
      firstInvalidField.focus();
    }

    updateTotals();
  });
</script>
